                  "children": [
                    {
                      "type": "text",
                      "id": "h0Ity",
                      "name": "ruleP1",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Parliamentary elections are scheduled to be held in Hungary on April 12 2026.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "JrFID",
                      "name": "ruleP2",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "This market will resolve to the individual who is next officially appointed and confirmed as Prime Minister of Hungary following the 2026 parliamentary election.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "VKjIz",
                      "name": "ruleP3",
                      "fill": "$accent-red",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "To count for resolution, the individual must be formally elected and appointed to the role of Prime Minister. Any interim or caretaker Prime Minister will not count toward the resolution of this market.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "LIhuF",
                      "name": "ruleP4",
                      "fill": "$accent-red",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "If no such Prime Minister is confirmed by December 31, 2026, 11:59 PM ET, this market will resolve to \"Other.\"",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "m4E2s",
                      "name": "ruleP5",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The primary resolution source for this market will be official information from the Government of Hungary; however, a consensus of credible reporting may also be used.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
